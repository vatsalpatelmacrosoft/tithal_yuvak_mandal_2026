{
    "name": "tdd/management-backend",
    "description": "Yuvak Sabha Management System - PHP Backend",
    "type": "project",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "endroid/qr-code": "For local QR code generation (optional, API fallback available)"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-unit": "phpunit --testsuite Unit",
        "test-feat": "phpunit --testsuite Feature",
        "migrate": "php migrate.php"
    }
}